---
import Base from '../layouts/Base.astro';

const skillGroups = [
  { label: 'Languages',  items: ['C', 'C++', 'Python', 'Verilog'] },
  { label: 'Hardware',   items: ['FPGA', 'STM32', '基板設計', '保護回路'] },
  { label: 'Platforms',  items: ['Linux', 'Ubuntu', 'SQLite', 'Git', 'GitHub'] },
  { label: 'AI Domains', items: ['異常検知', '時系列分析', '特徴量設計', '信号処理', 'LLM活用設計'] },
];

const career = [
  { years: '20年+', label: '製品エンジニア（ハードウェア）', detail: '組込み・FPGA・産業向け基板の設計と実装' },
  { years: '10年+', label: 'AI / 機械学習エンジニア', detail: '組込み AI・異常検知・信号処理の実装' },
  { years: '10年+', label: 'バックエンドエンジニア', detail: '産業システムのデータ処理・自動化' },
];
---
<Base title="About — K. NISHIMURA" description="経歴・スキル・仕事のしかた。組込み・産業AI 20年。">
  <h1>About</h1>

  <p class="lede">
    組込みと産業向けの AI を中心に、20年以上エンジニアをしています。ハードウェアに触りながら、ファームウェア、データ処理、AI モデルの実装まで一通り手を動かしてきました。
  </p>

  <h2>経歴</h2>
  <ul>
    {career.map(c => (
      <li><strong>{c.years}</strong> — {c.label}：{c.detail}</li>
    ))}
  </ul>
  <p class="meta-note">※複数領域を並行して担当した期間を含みます。総従事年数は 20+ 年。</p>

  <h2>得意領域</h2>
  <ul>
    <li>FPGA / Verilog の設計・検証・第三者レビュー</li>
    <li>マイコン（STM32 など）ファームウェア</li>
    <li>Python での業務自動化、データ処理、異常検知</li>
    <li>産業 IoT・センシング基板の保護回路や信号処理</li>
    <li>AI / 機械学習モデルの組込み実装と運用</li>
  </ul>

  <h2>スキル</h2>
  {skillGroups.map(g => (
    <div class="tag-group">
      <h3>{g.label}</h3>
      <ul class="tag-list">
        {g.items.map(i => <li>{i}</li>)}
      </ul>
    </div>
  ))}

  <h2>仕事のしかた</h2>
  <ul>
    <li>着手前に技術リスク、対応範囲、前提条件を明文化します。</li>
    <li>費用対効果が低いと判断した場合は、代替案または見送り判断を提示します。</li>
    <li>「動かした」を優先します。提案には動くコードや実測データを添えます。</li>
    <li>連絡は原則 24 時間以内に返信。作業時間帯（平日夜・土日中心）は着手前に共有します。</li>
  </ul>
</Base>
