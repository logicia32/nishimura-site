---
import type { Article } from '../data/articles';

interface Props {
  articles: Article[];
  /** Fallback link target when an article has no specific URL. */
  profileUrl?: string;
  profileLabel?: string;
}

const {
  articles,
  profileUrl = 'https://zenn.dev/logicia32',
  profileLabel = 'Zenn で探す →',
} = Astro.props;
---
<ul class="article-list">
  {articles.map(a => (
    <li>
      <time datetime={a.date} class="date">{a.date}</time>
      {a.url
        ? <a href={a.url} target="_blank" rel="noopener">{a.title}</a>
        : (
          <span class="title-with-hint">
            <span class="plain-title">{a.title}</span>
            <a class="hint" href={profileUrl} target="_blank" rel="noopener">{profileLabel}</a>
          </span>
        )
      }
    </li>
  ))}
</ul>

<style>
  .article-list {
    list-style: none;
    padding: 0;
    max-width: 100%;
  }
  .article-list li {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  @media (min-width: 640px) {
    .article-list li {
      flex-direction: row;
      align-items: baseline;
      gap: 1rem;
    }
  }
  .article-list .date {
    font-family: var(--font-mono);
    color: var(--muted);
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    flex-shrink: 0;
    min-width: 6.5rem;
  }
  .article-list a {
    color: var(--fg);
    font-weight: 500;
    border-bottom: 1px solid transparent;
  }
  .article-list a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .title-with-hint {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 0.85rem;
  }
  .title-with-hint .plain-title {
    color: var(--fg);
    font-weight: 500;
  }
  .title-with-hint .hint {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 400;
  }
  .title-with-hint .hint:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
