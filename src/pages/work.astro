---
import Base from '../layouts/Base.astro';
import ServiceSection from '../components/ServiceSection.astro';
import { services } from '../data/services';
---
<Base title="Work — 受託メニュー" description="組込み・FPGA レビュー、Python 業務自動化、産業AI 導入相談。価格・納期目安。">
  <h1>Work</h1>

  <p class="lede">
    組込み・FPGA・産業 AI の設計レビュー、実装支援、技術調査を小さな単位からお受けしています。
  </p>

  <div class="cta-row">
    <a class="button" href="/contact/">フォームで相談する</a>
    <a class="button secondary" href="https://coconala.com/users/6098038" target="_blank" rel="noopener">ココナラで相談する</a>
    <a class="button secondary" href="https://github.com/logicia32" target="_blank" rel="noopener">GitHub(過去の実装を見る)</a>
  </div>

  {services.map(service => <ServiceSection service={service} />)}

  <section>
    <h2>進め方</h2>
    <ol>
      <li>お問い合わせ(要件・背景・期待する成果物を簡単に)</li>
      <li>無料で見積もり相談(できること／できないことを正直にお伝え)</li>
      <li>合意のうえで着手 → メッセージ中心の非同期で進行</li>
      <li>納品・お渡し(必要に応じて口頭でのフォロー)</li>
    </ol>
  </section>

  <section>
    <h2>お問い合わせ</h2>
    <p>
      <a href="/contact/">フォーム</a> または <a href="https://coconala.com/users/6098038" target="_blank" rel="noopener">ココナラ</a> 経由でお願いします。GitHub は過去の実装の確認用にご利用ください。件名／本文に「相談内容・希望期限・予算感」を含めていただけるとスムーズです。
    </p>
    <p>
      返信は<strong>原則 24 時間以内</strong>。作業時間帯(平日夜・土日中心)は着手前に共有します。
    </p>
    <p class="meta-note">価格・納期はあくまで目安です。要件によっては事前にスコープを区切り、段階見積もりで進めることもあります。</p>
  </section>
</Base>
