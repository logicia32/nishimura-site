---
const links = [
  { href: '/',         label: 'TOP' },
  { href: '/about/',   label: 'About' },
  { href: '/work/',    label: 'Work' },
  { href: '/projects/',label: 'Projects' },
  { href: '/writing/', label: 'Writing' },
  { href: '/contact/', label: 'Contact' },
];
const path = Astro.url.pathname;
---
<header class="site-header">
  <a href="/" class="brand">
    <img
      src="/img/snowball-128.png"
      alt=""
      width="40"
      height="40"
      class="brand-mark"
      decoding="async"
    />
    <span class="brand-name">K. NISHIMURA</span>
  </a>
  <nav aria-label="主要ナビゲーション">
    <ul>
      {links.map(l => (
        <li>
          <a
            href={l.href}
            class={path === l.href ? 'active' : ''}
            aria-current={path === l.href ? 'page' : undefined}
          >{l.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand:focus-visible { outline: none; }
  .brand:focus-visible .brand-mark {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--fg-strong);
    border-bottom: 0 !important;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
  }
  .brand:hover { color: var(--accent); }
  .brand:hover .brand-mark {
    box-shadow: 0 0 0 2px var(--accent);
    transform: scale(1.05);
  }
  .brand-mark {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg-elev);
    box-shadow: 0 0 0 1px var(--border);
    transition: box-shadow var(--tx), transform var(--tx);
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .brand:hover .brand-mark { transform: none; }
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    font-size: 0.92rem;
  }
  nav a {
    color: var(--muted);
    border-bottom: 0 !important;
    position: relative;
    padding-bottom: 4px;
  }
  nav a::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--tx);
  }
  nav a:hover { color: var(--fg-strong); }
  nav a:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  nav a.active {
    color: var(--fg-strong);
    font-weight: 600;
  }
  nav a.active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  @media (max-width: 640px) {
    .site-header {
      flex-direction: column;
      align-items: flex-start;
      padding-bottom: 0;
    }
    nav {
      width: 100%;
      overflow-x: auto;
      scrollbar-width: thin;
      -webkit-overflow-scrolling: touch;
      padding: 0.25rem 0 0.4rem;
    }
    nav ul {
      flex-wrap: nowrap;
      gap: 1.2rem;
      white-space: nowrap;
      scroll-snap-type: x proximity;
    }
    nav li { scroll-snap-align: start; }
  }
</style>
