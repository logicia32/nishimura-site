---
import Base from '../layouts/Base.astro';

const projects = [
  {
    name: 'urekko',
    summary: 'スキルマーケットの公開データを毎朝自動収集し、売れ筋・新着・価格動向を Markdown レポート化する CLI。',
    tags: ['Python', 'sqlite', 'BeautifulSoup', 'cron'],
    evidence: [
      '毎朝 7:30 cron で継続実行し、日次レポートを自動生成',
      '価格・実績・カテゴリを SQLite に履歴保存',
      '前日差分・カテゴリ別中央値・新着件数を含むレポート構成',
      '価格パース不具合を検出 → 修正 → 過去データの一括補正まで対応',
    ],
    article: null,
    code: null,
    note: '公開範囲を制限',
    noteReason: '対象サイトの利用規約に配慮し、コードは非公開',
  },
  {
    name: 'code-aide',
    summary: '複数 LLM を使い分け、コードレビュー・差分提案・コスト見積もりを CLI から実行する支援ツール。Claude / Codex / Gemini / OpenRouter を OpenRouter 経由で統一インタフェース化。',
    tags: ['Python', 'LLM', 'MCP', 'OpenRouter'],
    evidence: [
      'MCP サーバとして登録、Claude Code から直接呼び出し可',
      'レビュー 1 回あたりの概算コストを末尾表示',
      'review / ask / propose / map / find などのサブコマンド',
    ],
    code: 'https://github.com/logicia32/code-aide',
    article: null,
  },
  {
    name: 'Z80 並列計算・低レイヤ再構築',
    summary: '4 台の Z80（ゼッパチ）で円周率を並列計算する実験と、最小ランタイムを 0x0000 から立ち上げて C の printf と二分探索を動かす再構築。',
    tags: ['Z80', 'C', '組込み'],
    evidence: [
      '電源オン直後の 0x0000 から printf 相当を実装',
      '4 台構成での並列計算と Amdahl 効率の実測',
      '記事に動作ログとコードを併載',
    ],
    article: 'https://zenn.dev/logicia32',
  },
  {
    name: 'PySpice × 4 次 LPF（E12 / E24 で実装）',
    summary: 'AD コンバータ前段の 4 次ローパスフィルタを E12 / E24 系列で組み、PySpice で本物の Bode 線図を出すまでの実証。',
    tags: ['PySpice', '回路設計', 'Bode'],
    evidence: [
      '部品定数を実在 E 系列に丸めた前後の特性差を比較',
      'PySpice で AC 解析・位相応答・群遅延を可視化',
      '17,500 字の記事に手順と再現コードを収録',
    ],
    article: 'https://zenn.dev/logicia32/articles/2026-05-20-pyspice-4th-order-lpf',
  },
  {
    name: '実機なし STM32 三相電力測定（2 電力計法）',
    summary: '実機を使わずに Python の中だけで STM32 を動かし、不平衡・低力率を含めた三相電力を検証する。',
    tags: ['STM32', 'Python', '信号処理'],
    evidence: [
      'ファーム側ロジックを Python 上でビット精度シミュレート',
      '不平衡・低力率条件下での誤差傾向を定量化',
      '実機なしの段階で設計判断を確定できる構成',
    ],
    article: 'https://zenn.dev/logicia32',
  },
  {
    name: 'RTL の合成 / 配置配線で剥がれるもの（Yosys × iverilog）',
    summary: '同じ Verilog を Yosys と iverilog で 3 回シミュレートし、合成前後で振る舞いが変わる箇所を観察する。',
    tags: ['Verilog', 'Yosys', 'iverilog', 'FPGA'],
    evidence: [
      'RTL / Synth / Place-and-route の 3 段階で同じ刺激を流す',
      '合成最適化で消えた信号と残った信号を可視化',
      '検証戦略の落とし穴を実例で記録',
    ],
    article: 'https://zenn.dev/logicia32',
  },
];
---
<Base title="Projects — K. NISHIMURA" description="urekko, code-aide, FPGA / 組込み / Python 実証プロジェクト。">
  <h1>Projects</h1>

  <p class="lede">
    現場の関心事を、手を動かして検証したものを並べています。多くは Zenn の記事と動くコードがセットになっています。
  </p>

  <div class="cards cards--stack">
    {projects.map(p => {
      const mainLink = p.article || p.code;
      return (
        <article class="card project-card">
          <h3>
            {mainLink ? <a href={mainLink} target="_blank" rel="noopener">{p.name}</a> : p.name}
          </h3>
          <ul class="tag-list">
            {p.tags.map(t => <li>{t}</li>)}
          </ul>
          <p>{p.summary}</p>
          <ul class="evidence-list">
            {p.evidence.map(e => <li>{e}</li>)}
          </ul>
          <div class="project-link-row">
            {p.article && <a href={p.article} target="_blank" rel="noopener">記事 →</a>}
            {p.code && <a href={p.code} target="_blank" rel="noopener">コード →</a>}
            {p.note && (
              <span class="private-note">
                <span class="badge">PRIVATE</span>
                <span class="reason">{p.noteReason ?? p.note}</span>
              </span>
            )}
          </div>
        </article>
      );
    })}
  </div>
</Base>
